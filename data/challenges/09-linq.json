{"id":"09-linq","level":5,"title":"LINQ Queries","category":"csharp","categoryLabel":"C#","points":300,"description":"Fix LINQ syntax.","objectives":["Use Where, Select, Sum","Use => not ->"],"hints":[".Where(x => condition)"],"hintPenalty":35,"validationType":"csharp-output","files":[{"filename":"Linq.cs","language":"csharp","editable":true,"content":"using System;\nusing System.Linq;\nusing System.Collections.Generic;\n\nclass LinqDemo\n{\n  static void Main(string[] args)\n  {\n    var nums = new List<int> {1,2,3,4,5};\n    var evens = nums.Filter(n -> n % 2 == 0).Map(n -> n * 2).ToList();\n    int sum = nums.Reduce((a,b) -> a + b);\n  }\n}"}],"validation":{"checks":[{"description":"Where","astRule":{"type":"contains-string","value":".Where(n =>"},"points":25},{"description":"Select","astRule":{"type":"contains-string","value":".Select(n =>"},"points":25},{"description":"No ->","astRule":{"type":"no-string","value":"->"},"points":25},{"description":"Sum()","astRule":{"type":"contains-string","value":".Sum()"},"points":25}]},"unlockRequires":["08-exceptions"]}
