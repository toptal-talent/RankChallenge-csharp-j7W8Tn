{"id":"06-inheritance","level":3,"title":"Inheritance","category":"csharp","categoryLabel":"C#","points":200,"description":"Fix inheritance syntax.","objectives":["Use colon for inheritance","Use base() for parent constructor"],"hints":["class Child : Parent"],"hintPenalty":25,"validationType":"csharp-output","files":[{"filename":"Animals.cs","language":"csharp","editable":true,"content":"using System;\n\nclass Animal\n{\n  protected string name;\n  public Animal(string name) { this.name = name; }\n  public virtual void Speak() { Console.WriteLine($\"{name} speaks\"); }\n}\n\nclass Dog extends Animal\n{\n  public Dog(string name) { super(name); }\n  public void Speak() { Console.WriteLine($\"{name} barks\"); }\n}"}],"validation":{"checks":[{"description":"Colon inheritance","astRule":{"type":"contains-string","value":"class Dog : Animal"},"points":35},{"description":"base()","astRule":{"type":"contains-string","value":": base(name)"},"points":35},{"description":"override","astRule":{"type":"contains-string","value":"public override void Speak"},"points":30}]},"unlockRequires":["05-classes"]}
