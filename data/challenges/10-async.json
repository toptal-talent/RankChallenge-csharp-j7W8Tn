{"id":"10-async","level":5,"title":"Async/Await","category":"csharp","categoryLabel":"C#","points":300,"description":"Fix async method signatures.","objectives":["Add async keyword","Return Task<T>","Use await"],"hints":["async Task<string> FetchAsync()"],"hintPenalty":40,"validationType":"csharp-output","files":[{"filename":"Async.cs","language":"csharp","editable":true,"content":"using System;\nusing System.Threading.Tasks;\n\nclass AsyncDemo\n{\n  static void Main(string[] args) { RunAsync(); }\n  \n  static void RunAsync()\n  {\n    string result = FetchDataAsync();\n    Console.WriteLine(result);\n  }\n  \n  static string FetchDataAsync()\n  {\n    Task.Delay(100);\n    return \"Hello\";\n  }\n}"}],"validation":{"checks":[{"description":"await RunAsync","astRule":{"type":"contains-string","value":"await RunAsync()"},"points":25},{"description":"async Task RunAsync","astRule":{"type":"contains-string","value":"static async Task RunAsync"},"points":25},{"description":"Task<string>","astRule":{"type":"contains-string","value":"static async Task<string> FetchDataAsync"},"points":25},{"description":"await Task.Delay","astRule":{"type":"contains-string","value":"await Task.Delay"},"points":25}]},"unlockRequires":["09-linq"]}
