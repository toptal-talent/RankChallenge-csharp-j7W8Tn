{"id":"07-interfaces","level":4,"title":"Interfaces","category":"csharp","categoryLabel":"C#","points":250,"description":"Fix interface implementation.","objectives":["Interface name starts with I","Use colon to implement"],"hints":["interface IName { }"],"hintPenalty":30,"validationType":"csharp-output","files":[{"filename":"Calculator.cs","language":"csharp","editable":true,"content":"using System;\n\ninterface Calculator\n{\n  int Add(int a, int b) { return a + b; }\n  int Subtract(int a, int b);\n}\n\nclass SimpleCalculator implements Calculator\n{\n  public int Add(int a, int b) { return a + b; }\n  public int Subtract(int a, int b) { return a - b; }\n}"}],"validation":{"checks":[{"description":"ICalculator","astRule":{"type":"contains-string","value":"interface ICalculator"},"points":30},{"description":"No body","astRule":{"type":"contains-string","value":"int Add(int a, int b);"},"points":35},{"description":"Colon implements","astRule":{"type":"contains-string","value":"SimpleCalculator : ICalculator"},"points":35}]},"unlockRequires":["06-inheritance"]}
